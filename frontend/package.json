  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  }
}
